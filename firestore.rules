rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /photography/{category} {
      allow read: if true;
      allow write: if request.auth != null;

      match /photos/{photoId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /music/{document} {
      allow read: if true;
      allow write: if request.auth != null;

      match /tracks/{trackId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

  }
}