rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /images/projects/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /images/photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}